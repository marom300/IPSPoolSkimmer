{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "BaseTopic",
            "caption": "Basis-Topic (wie in der Sensor-Firmware)"
        },
        {
            "type": "ExpansionPanel",
            "caption": "Messplan (Sensor)",
            "items": [
                {
                    "type": "Select",
                    "name": "Mode",
                    "caption": "Modus",
                    "options": [
                        { "caption": "Täglich zu fester Uhrzeit", "value": "daily" },
                        { "caption": "Intervall (alle X Minuten)", "value": "interval" }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        { "type": "NumberSpinner", "name": "WakeHour", "caption": "Mess-Stunde", "minimum": 0, "maximum": 23 },
                        { "type": "NumberSpinner", "name": "WakeMin", "caption": "Mess-Minute", "minimum": 0, "maximum": 59 }
                    ]
                },
                {
                    "type": "NumberSpinner",
                    "name": "IntervalMin",
                    "caption": "Mess-Intervall (Minuten, nur Modus Intervall)",
                    "minimum": 1,
                    "maximum": 1440
                },
                {
                    "type": "NumberSpinner",
                    "name": "CheckinMin",
                    "caption": "Config-Check-in alle X Minuten (0 = aus)",
                    "minimum": 0,
                    "maximum": 1440
                },
                {
                    "type": "NumberSpinner",
                    "name": "OffsetCm",
                    "caption": "Kalibrier-Offset (cm)",
                    "digits": 1,
                    "minimum": -100,
                    "maximum": 100
                },
                {
                    "type": "NumberSpinner",
                    "name": "NMeas",
                    "caption": "Einzelmessungen pro Zyklus (Median)",
                    "minimum": 3,
                    "maximum": 50
                },
                {
                    "type": "Label",
                    "caption": "Änderungen mit 'Konfiguration an Sensor senden' übertragen (Sensor übernimmt sie beim nächsten Aufwachen)."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Automatisches Nachfüllen",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "AutoRefill",
                    "caption": "Automatisches Nachfüllen aktiv"
                },
                {
                    "type": "SelectScript",
                    "name": "RefillScriptID",
                    "caption": "Start-Skript (startet Hunter-Zone für $_IPS['DURATION'] Minuten)"
                },
                {
                    "type": "RowLayout",
                    "items": [
                        { "type": "NumberSpinner", "name": "PoolArea", "caption": "Wasseroberfläche (m²)", "digits": 2 },
                        { "type": "NumberSpinner", "name": "FlowRate", "caption": "Zuflussrate (l/min)", "digits": 1 }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        { "type": "NumberSpinner", "name": "TargetLevelCm", "caption": "Ziel-Abstand Sensor→Wasser (cm)", "digits": 1 },
                        { "type": "NumberSpinner", "name": "ToleranceCm", "caption": "Toleranz (cm)", "digits": 1 }
                    ]
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Sicherheit (Nachfüllen)",
            "items": [
                {
                    "type": "RowLayout",
                    "items": [
                        { "type": "NumberSpinner", "name": "MaxRunMin", "caption": "Max. Minuten pro Portion", "minimum": 1, "maximum": 240 },
                        { "type": "NumberSpinner", "name": "DailyBudgetMin", "caption": "Tagesbudget (Minuten)", "minimum": 1, "maximum": 600 }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        { "type": "NumberSpinner", "name": "MaxAgeMin", "caption": "Max. Messwert-Alter (Minuten)", "minimum": 1, "maximum": 1440 },
                        { "type": "NumberSpinner", "name": "VerifyFactor", "caption": "Erfolgskontrolle: Mindest-Anteil", "digits": 2, "minimum": 0.1, "maximum": 1 }
                    ]
                },
                {
                    "type": "RowLayout",
                    "items": [
                        { "type": "NumberSpinner", "name": "PlausMinCm", "caption": "Plausibel ab (cm)", "digits": 1 },
                        { "type": "NumberSpinner", "name": "PlausMaxCm", "caption": "Plausibel bis (cm)", "digits": 1 }
                    ]
                },
                {
                    "type": "NumberSpinner",
                    "name": "CalibMinutes",
                    "caption": "Dauer Kalibrierlauf (Minuten)",
                    "minimum": 1,
                    "maximum": 60
                },
                {
                    "type": "Label",
                    "caption": "Prinzip: Es wird immer nur eine zeitbegrenzte Portion beauftragt - der Hunter stoppt selbst (Totmann-Prinzip). Budget, Plausibilität und Erfolgskontrolle sichern zusätzlich ab."
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Dashboard-Verknüpfungen (optional, z.B. Violet-Steuerung)",
            "items": [
                { "type": "SelectVariable", "name": "DashWaterTemp", "caption": "Wassertemperatur" },
                { "type": "SelectVariable", "name": "DashPumpStage", "caption": "Pumpenstufe" },
                { "type": "SelectVariable", "name": "DashPumpRpm", "caption": "Pumpen-Drehzahl (RPM)" },
                { "type": "SelectVariable", "name": "DashPh", "caption": "pH-Wert" },
                { "type": "SelectVariable", "name": "DashRedox", "caption": "Redox" },
                { "type": "SelectVariable", "name": "DashExtra1", "caption": "Zusatzwert 1" },
                { "type": "SelectVariable", "name": "DashExtra2", "caption": "Zusatzwert 2" },
                {
                    "type": "Label",
                    "caption": "Diese Werte liefert das Modul gebündelt über PSK_GetDashboardData() an das (kommende) Pool-Dashboard."
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Konfiguration an Sensor senden",
            "onClick": "PSK_SendConfig($id);"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "Konfig-Portal öffnen (nächstes Aufwachen)",
                    "onClick": "PSK_RequestPortal($id);"
                },
                {
                    "type": "Button",
                    "caption": "OTA-Fenster öffnen (nächstes Aufwachen)",
                    "onClick": "PSK_RequestOta($id);"
                }
            ]
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "Kalibrierlauf starten (Zuflussrate messen)",
                    "onClick": "PSK_StartCalibration($id);"
                },
                {
                    "type": "Button",
                    "caption": "Nachfüll-Sperre quittieren",
                    "onClick": "PSK_AcknowledgeLock($id);"
                }
            ]
        }
    ],
    "status": []
}
